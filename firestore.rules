rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 3. Validation helper for Tournament schema
    function isValidTournament(data) {
      return data.keys().hasAll(['matches', 'updatedAt'])
        && data.keys().size() == 2
        && data.matches is list
        && data.updatedAt is timestamp;
    }

    // 4. Tournaments Collection Match
    match /tournaments/{id} {
      allow get: if isValidId(id);
      allow create, update: if isValidId(id)
        && isValidTournament(incoming())
        && incoming().updatedAt == request.time;
      allow delete: if false;
    }
  }
}
